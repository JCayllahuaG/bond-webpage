---
import { assetUrl } from '../lib/assets';
import { defaultLang, normalizeLang, type Lang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
	lang?: Lang;
}

const {
  title = 'BOND',
  description = 'BOND: streetwear elegante y minimalista. Descubre la coleccion Fundamentals y nuestro catalogo oficial.',
  ogImage = assetUrl('/catalog/extracted/page-01-img-01.png'),
  canonical,
  noindex = false,
  type = 'website',
	lang = defaultLang,
} = Astro.props;

const resolvedLang = normalizeLang(lang);

const canonicalUrl = canonical ?? Astro.url?.toString();
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const faviconVersion = '2';
const faviconSvg = assetUrl('/favicon.svg');
const faviconIco = assetUrl('/favicon.ico');

function withVersion(url: string) {
	return `${url}${url.includes('?') ? '&' : '?'}v=${faviconVersion}`;
}

const siteUrl = Astro.site?.toString();
const orgUrl = siteUrl ?? canonicalUrl;
const orgJsonLd = orgUrl
	? {
			'@context': 'https://schema.org',
			'@type': 'Organization',
			name: 'BOND',
			url: orgUrl,
			logo: assetUrl('/icons/bond_logo.svg'),
			sameAs: ['https://instagram.com/bondperu__'],
		}
	: null;

const websiteJsonLd = orgUrl
	? {
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: 'BOND',
			url: orgUrl,
		}
	: null;
---
<!doctype html>
<html lang={resolvedLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta property="og:site_name" content="BOND" />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		{orgJsonLd && <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />}
		{websiteJsonLd && <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />}
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,400;6..96,600;6..96,700&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href={withVersion(faviconSvg)} />
		<link rel="icon" type="image/x-icon" href={withVersion(faviconIco)} />
		<link rel="shortcut icon" href={withVersion(faviconIco)} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script define:vars={{ defaultLang }}>
			(() => {
				const storageKey = 'bond-language';
				const currentUrl = new URL(window.location.href);
				const pathname = currentUrl.pathname;
				const requestedLang = pathname === '/en' || pathname.startsWith('/en/')
					? 'en'
					: currentUrl.searchParams.get('lang') === 'en'
						? 'en'
						: currentUrl.searchParams.get('lang') === 'es'
							? 'es'
							: null;
				const storedLang = window.localStorage.getItem(storageKey);
				const resolvedLang = requestedLang === 'en' || requestedLang === 'es'
					? requestedLang
					: storedLang === 'en'
						? 'en'
						: defaultLang;

				const basePath = pathname === '/en' ? '/' : pathname.startsWith('/en/') ? pathname.slice(3) : pathname;
				const shouldUseEnglishPath = resolvedLang === 'en';
				const targetPath = shouldUseEnglishPath
					? basePath === '/' ? '/en' : `/en${basePath}`
					: basePath;

				if (pathname !== targetPath) {
					currentUrl.pathname = targetPath;
					currentUrl.search = '';
					window.localStorage.setItem(storageKey, resolvedLang);
					window.location.replace(currentUrl.toString());
					return;
				}

				window.localStorage.setItem(storageKey, resolvedLang);
				document.documentElement.lang = resolvedLang;

				document.addEventListener('click', (event) => {
					const target = event.target instanceof Element ? event.target.closest('[data-language-option]') : null;
					if (!target) return;

					const value = target.getAttribute('data-language-option');
					if (value === 'en' || value === 'es') {
						window.localStorage.setItem(storageKey, value);
					}
				});
			})();
		</script>
	</head>
<body class="m-0 w-full overflow-x-hidden">
		<slot />
	</body>
	</html>

<style>
	html,
	body {
		height: 100%;
	}
</style>
