---
import { assetUrl } from '../lib/assets';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,400;6..96,600;6..96,700&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href={assetUrl("/favicon.svg")} />
		<link rel="icon" href={assetUrl("/favicon.ico")} />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
<body class="m-0 w-full overflow-x-hidden">
		<slot />
	</body>
	</html>

<style>
	html,
	body {
		height: 100%;
	}
</style>
