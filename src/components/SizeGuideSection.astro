---
import { assetUrl } from '../lib/assets';

const guides = [
  {
    id: 'size-polo',
    name: 'Polo',
    image: assetUrl('/catalog/sizes/Polo.svg'),
    alt: 'Guia de tallas para polo con medidas numeradas',
    rows: [
      { size: 'S', chest: '58', length: '63', sleeve: '24' },
      { size: 'M', chest: '60', length: '65', sleeve: '26' },
    ],
  },
  {
    id: 'size-camisero',
    name: 'Camisero',
    image: assetUrl('/catalog/sizes/Camisero.svg'),
    alt: 'Guia de tallas para camisero con medidas numeradas',
    rows: [
      { size: 'M', chest: '58', length: '68', sleeve: '28' },
      { size: 'L', chest: '60', length: '70', sleeve: '30' },
    ],
  },
  {
    id: 'size-camisa',
    name: 'Camisa',
    image: assetUrl('/catalog/sizes/Camisa.svg'),
    alt: 'Guia de tallas para camisa con medidas numeradas',
    rows: [
      { size: 'M', chest: '76', length: '66', sleeve: '24' },
      { size: 'L', chest: '78', length: '68', sleeve: '26' },
    ],
  },
];

const measurements = [
  { key: 'chest', label: 'A. Pecho' },
  { key: 'length', label: 'B. Largo' },
  { key: 'sleeve', label: 'C. Manga' },
];

const formatCm = (value: string) => (value === '___' ? value : `${value} cm`);
---

<section data-scroll-section class="bg-[#ececec] px-5 py-12 text-[#101010] sm:px-8 sm:py-14 lg:px-12 lg:py-16">
  <div class="mx-auto w-full max-w-375">
    <div class="max-w-190">
      <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-[#3a3a3a]">Fundamentals</p>
      <h2 class="catalog-serif mt-2 text-[32px] uppercase leading-none sm:text-[44px] md:text-[52px]">Guía de tallas</h2>
      <p class="mt-5 text-[12px] font-medium uppercase leading-normal text-[#2f2f2f] sm:text-[13px]">
        Las medidas están expresadas en cm. Para elegir tu talla, mide tu pecho, largo y manga y compara con la tabla de cada modelo. Si estas entre dos tallas, te recomendamos elegir la talla mayor para un ajuste mas cómodo.
      </p>
    </div>

    <div class="mt-10 space-y-8 lg:space-y-10">
      {
        guides.map((guide) => (
          <article id={guide.id} class="grid gap-6 scroll-mt-24 rounded-2xl border border-[#d4d4d4] bg-white p-5 shadow-[0_18px_50px_rgba(0,0,0,0.04)] sm:p-6 lg:grid-cols-[0.9fr_1.1fr] lg:gap-8">
            <div>
              <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-[#454545]">Modelo</p>
              <h3 class="catalog-serif mt-2 text-[28px] uppercase leading-none sm:text-[36px]">{guide.name}</h3>

              <img
                src={guide.image}
                alt={guide.alt}
                class="mt-6 w-full rounded-xl border border-[#e0e0e0] bg-[#f5f5f5] object-contain"
                loading="lazy"
                decoding="async"
              />

              <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-[#434343] sm:text-[12px]">
                {
                  measurements.map((measurement) => (
                    <span>{measurement.label}</span>
                  ))
                }
              </div>
            </div>

            <div class="overflow-hidden rounded-xl border border-[#d8d8d8]">
              <table class="w-full border-collapse">
                <thead class="bg-[#f4f4f4] text-left text-[11px] uppercase tracking-[0.14em] text-[#333] sm:text-[12px]">
                  <tr>
                    <th class="px-3 py-3 font-semibold sm:px-4">Talla</th>
                    {measurements.map((measurement) => (
                      <th class="px-3 py-3 font-semibold sm:px-4">{measurement.label}</th>
                    ))}
                  </tr>
                </thead>
                <tbody class="divide-y divide-[#e8e8e8] bg-white text-[12px] sm:text-[13px]">
                  {
                    guide.rows.map((row) => (
                      <tr>
                        <td class="px-3 py-4 font-semibold uppercase tracking-[0.12em] text-[#111] sm:px-4">{row.size}</td>
                        <td class="px-3 py-4 text-[#6b6b6b] sm:px-4">{formatCm(row.chest)}</td>
                        <td class="px-3 py-4 text-[#6b6b6b] sm:px-4">{formatCm(row.length)}</td>
                        <td class="px-3 py-4 text-[#6b6b6b] sm:px-4">{formatCm(row.sleeve)}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .catalog-serif {
    font-family: "Bodoni Moda", serif;
    font-optical-sizing: auto;
    font-style: normal;
    font-weight: 600;
  }
</style>