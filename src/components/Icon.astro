---
import { assetUrl } from '../lib/assets';

interface Props {
  name?: string;
  src?: string;
  mode?: "mask" | "image";
  size?: number;
  color?: string;
  class?: string;
  decorative?: boolean;
  label?: string;
}

const {
  name,
  src,
  mode,
  size = 28,
  color = "#ffffff",
  class: className = "",
  decorative = true,
  label,
} = Astro.props;

const iconPath = src ?? (name ? assetUrl(`/icons/${name}.svg`) : "");
const resolvedMode = mode ?? (src ? "image" : "mask");
const ariaHidden = decorative ? "true" : undefined;
const ariaLabel = decorative ? undefined : (label ?? name ?? "icon");
---

{
  resolvedMode === "image" ? (
    <img
      src={iconPath}
      alt={decorative ? "" : ariaLabel}
      aria-hidden={ariaHidden}
      width={size}
      height={size}
      class={`inline-block align-middle ${className}`}
      loading="lazy"
      decoding="async"
      style={`width: ${size}px; height: ${size}px;`}
    />
  ) : (
    <span
      class={`inline-block align-middle ${className}`}
      role={decorative ? undefined : "img"}
      aria-hidden={ariaHidden}
      aria-label={ariaLabel}
      style={`
        width: ${size}px;
        height: ${size}px;
        background-color: ${color};
        mask-image: url('${iconPath}');
        mask-repeat: no-repeat;
        mask-position: center;
        mask-size: contain;
        -webkit-mask-image: url('${iconPath}');
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-position: center;
        -webkit-mask-size: contain;
      `}
    ></span>
  )
}
