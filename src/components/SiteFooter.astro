---
import Icon from './Icon.astro';
import { assetUrl } from '../lib/assets';

const footerContentWidth = "mx-auto w-[84vw] min-w-[80vw] max-w-384";
const footerLogoSrc = assetUrl("/icons/bond_logo.svg");
---

<footer class="bg-[#ececec] px-5 pb-4 pt-8 text-[#111] sm:px-8 md:px-10 lg:px-12">
  <div class:list={[footerContentWidth, "grid gap-8 sm:grid-cols-2 lg:grid-cols-6 lg:gap-x-3"]}>
    <div class="pt-1 sm:col-span-2 lg:col-span-1">
      <Icon src={footerLogoSrc} mode="image" size={52} decorative={false} label="Bond" />
    </div>

    <div class="lg:col-span-1">
        <h3 class="text-[14px] leading-none uppercase tracking-tight footer-serif">Our Brand</h3>
        <ul class="mt-5 space-y-1.5 text-[13px] font-medium uppercase text-[#222]">
          <li><a href="#" class="transition-opacity hover:opacity-70">About</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">Lookbook</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">Stories</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">Collaborations</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">Store Location</a></li>
        </ul>
    </div>

    <div class="lg:col-span-1">
        <h3 class="text-[14px] leading-none uppercase tracking-tight footer-serif">Information</h3>
        <ul class="mt-5 space-y-1.5 text-[13px] font-medium uppercase text-[#222]">
          <li><a href="#" class="transition-opacity hover:opacity-70">Track Order</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">Shipping & Returns</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">Size Guide</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">Sustainability</a></li>
        </ul>
    </div>

    <div class="lg:col-span-1">
        <h3 class="text-[14px] leading-none uppercase tracking-tight footer-serif">Socials</h3>
        <ul class="mt-5 space-y-1.5 text-[13px] font-medium uppercase text-[#222]">
          <li><a href="#" class="transition-opacity hover:opacity-70">Instagram</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">X.com</a></li>
          <li><a href="#" class="transition-opacity hover:opacity-70">TikTok</a></li>
        </ul>
    </div>

    <div class="lg:col-span-2">
        <h3 class="text-[14px] leading-none uppercase tracking-tight footer-serif">Join Our Community</h3>
        <p class="mt-5 max-w-sm text-[13px] font-medium uppercase leading-5 text-[#444]">
          Stay up to date with the latest collections, collaborations, and special projects.
        </p>
        <form class="mt-6 flex max-w-md gap-2" action="#" method="post">
          <label class="sr-only" for="footer-email">Email</label>
          <input
            id="footer-email"
            type="email"
            placeholder="Enter your email"
            class="h-10 flex-1 border border-[#cfcfcf] bg-transparent px-4 text-[13px] uppercase tracking-wide placeholder:text-[#666] focus:border-[#999] focus:outline-none"
          />
          <button
            type="submit"
            class="h-10 bg-[#111] px-5 text-[12px] font-semibold uppercase tracking-wide text-white transition-opacity hover:opacity-85"
          >
            Subscribe
          </button>
        </form>
    </div>
  </div>

  <div class:list={[footerContentWidth, "mt-16 flex flex-wrap items-center justify-between gap-4 text-[12px] uppercase text-[#555]"]}>
    <p>© 2025 • Bond</p>
    <p class="text-right">Privacy & Policy • Terms of Sale</p>
  </div>

  <div class:list={[footerContentWidth, "mt-2 overflow-hidden"]}>
    <p class="bond-wordmark -mb-3 flex w-full select-none justify-between text-[30vw] leading-none text-[#07090c] sm:-mb-5 sm:text-[24vw] lg:-mb-7 lg:text-[20vw]">
      <span>B</span>
      <span>O</span>
      <span>N</span>
      <span>D</span>
    </p>
  </div>
</footer>

<style>
  .footer-serif,
  .bond-wordmark {
    font-family: "Bodoni Moda", serif;
    font-optical-sizing: auto;
    font-style: normal;
  }

  .footer-serif {
    font-weight: 600;
    display: inline-block;
    transform: scaleY(1.12);
    transform-origin: left center;
  }

  .bond-wordmark {
    font-weight: 700;
    letter-spacing: -0.05em;
  }
</style>
