---
import Icon from './Icon.astro';
import { assetUrl } from '../lib/assets';

const navLinkClass = "text-base leading-7 font-light tracking-wide text-white/90 transition-transform duration-300 ease-out hover:-translate-y-0.5 hover:text-white";
---

<header class="hero-navbar-safe absolute inset-x-0 top-0 z-50">
  <nav class="mx-auto flex w-full items-center justify-center text-white sm:hidden">
    <div class="flex items-center gap-7">
      <a href="/catalog" class={navLinkClass}>NEW</a>
      <a href="/catalog" class={navLinkClass}>CATALOG</a>
      <a href="/catalog" class={navLinkClass}>SHOP</a>
    </div>
  </nav>

  <nav class="mx-auto hidden w-full items-center justify-between text-white sm:flex">
    <div class="flex items-center gap-7 sm:gap-8 md:gap-10">
      <a href="/" class="flex items-center" aria-label="Bond home">
        <Icon src={assetUrl('/icons/bond_logo.svg')} mode="image" size={28} class="opacity-95 brightness-0 invert" decorative={false} label="Bond" />
      </a>
      <a href="/catalog" class={navLinkClass}>NEW</a>
      <a href="/catalog" class={navLinkClass}>CATALOG</a>
      <a href="/catalog" class={navLinkClass}>SHOP ALL</a>
      <a href="#" class={`hidden sm:inline ${navLinkClass}`}>JOURNAL</a>
      <a href="#" class={`hidden sm:inline ${navLinkClass}`}>STORIES</a>
      <a href="#" class={`hidden sm:inline ${navLinkClass}`}>SEARCH</a>
    </div>

    <a href="#" class={navLinkClass}>CART (0)</a>
  </nav>
</header>

<style>
  .hero-navbar-safe {
    padding-top: calc(env(safe-area-inset-top, 0px) + 1.25rem);
    padding-left: calc(env(safe-area-inset-left, 0px) + 1rem);
    padding-right: calc(env(safe-area-inset-right, 0px) + 1rem);
  }

  @media (min-width: 640px) {
    .hero-navbar-safe {
      padding-left: calc(env(safe-area-inset-left, 0px) + 2rem);
      padding-right: calc(env(safe-area-inset-right, 0px) + 2rem);
    }
  }
</style>
