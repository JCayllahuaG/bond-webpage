---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import HeroNavbar from '../../components/HeroNavbar.astro';
import SizeGuideSection from '../../components/SizeGuideSection.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { assetUrl } from '../../lib/assets';
import { catalogCopy } from '../../lib/i18n';

const lang = 'en';
const copy = catalogCopy[lang];
const families = copy.families;
const sizeGuides = copy.sizeGuides;
---

<Layout
  lang={lang}
  title={copy.documentTitle}
  description={copy.documentDescription}
  ogImage={assetUrl('/catalog/extracted/page-01-img-01.png')}
>
  <section data-scroll-section class="relative isolate min-h-dvh overflow-hidden bg-[#d9d9d9] px-5 pb-10 pt-[calc(6rem+env(safe-area-inset-top,0px))] text-white sm:px-8 lg:px-12">
    <img
      src={assetUrl('/catalog/extracted/page-01-img-01.png')}
      alt={copy.hero.imageAlt}
      class="absolute inset-0 -z-20 h-full w-full object-cover object-top md:object-[50%_12%]"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      sizes="100vw"
    />
    <div class="absolute inset-0 -z-10 bg-linear-to-b from-black/35 via-black/45 to-black/70"></div>

    <HeroNavbar lang={lang} pathname={Astro.url.pathname} />
    <div class="mx-auto w-full max-w-375">
      <p class="text-[12px] font-semibold uppercase tracking-[0.24em] text-white/70">{copy.hero.eyebrow}</p>
      <h1 class="catalog-serif mt-3 text-[52px] uppercase leading-none sm:text-[72px] md:text-[92px]">BOND</h1>
      <p class="mt-4 max-w-170 text-[16px] uppercase tracking-[0.22em] text-white/90">{copy.hero.subtitle}</p>
      <p class="mt-10 max-w-170 text-[12px] font-medium uppercase leading-normal text-white/75 sm:text-[13px]">
        {copy.hero.description}
      </p>
      <a
        href={assetUrl(copy.hero.ctaHref)}
        target="_blank"
        rel="noreferrer"
        class="mt-8 inline-block border-b border-white/70 pb-1 text-[12px] font-semibold uppercase tracking-[0.16em] text-white transition-opacity hover:opacity-75"
      >
        {copy.hero.ctaLabel}
      </a>
    </div>
  </section>

  <section data-scroll-section class="bg-[#ececec] px-5 py-12 text-[#111] sm:px-8 sm:py-14 lg:px-12 lg:py-16">
    <div class="mx-auto grid w-full max-w-375 gap-8 lg:grid-cols-[1fr_1.05fr] lg:items-center lg:gap-14">
      <div class="max-w-185">
        <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-[#333]">{copy.about.eyebrow}</p>
        <h2 class="catalog-serif mt-3 text-[34px] uppercase leading-none sm:text-[46px] md:text-[56px]">{copy.about.title}</h2>
        <p class="mt-8 text-[12px] font-medium uppercase leading-normal text-[#2b2b2b] sm:text-[13px]">
          {copy.about.description}
        </p>
      </div>

      <img
        src={assetUrl('/catalog/extracted/page-02-img-01.png')}
        alt={copy.about.imageAlt}
        class="h-auto w-full rounded-xl object-cover"
        loading="lazy"
        decoding="async"
        sizes="(min-width: 1024px) 52vw, 100vw"
      />
    </div>
  </section>

  {
    families.map((family, index) => (
      <section data-scroll-section class="bg-[#ececec] px-5 py-10 text-[#111] sm:px-8 sm:py-12 lg:px-12 lg:py-14">
        <div class="mx-auto w-full max-w-375">
          <div class="grid gap-8 lg:grid-cols-[0.42fr_1fr] lg:gap-10">
            <div class="lg:sticky lg:top-8 lg:self-start">
              <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-[#3a3a3a]">{copy.about.eyebrow}</p>
              <h2 class="catalog-serif mt-2 text-[32px] uppercase leading-none sm:text-[44px] md:text-[52px]">{family.name}</h2>

              <p class="mt-6 text-[12px] font-medium uppercase leading-normal text-[#2f2f2f] sm:text-[13px]">
                {family.description}
              </p>

              <div class="mt-7 space-y-2 border-l border-[#c9c9c9] pl-4">
                <p class="text-[12px] font-semibold uppercase tracking-[0.12em] text-[#1e1e1e]">{family.price}</p>
                <p class="text-[12px] font-semibold uppercase tracking-[0.12em] text-[#3d3d3d]">{family.availability}</p>
                <p class="text-[12px] font-semibold uppercase tracking-[0.12em] text-[#3d3d3d]">{family.sizes}</p>
                <button
                  type="button"
                  data-open-size-guide={family.guideKey}
                  class="inline-block border-b border-[#222] pb-1 text-left text-[11px] font-semibold uppercase tracking-[0.16em] text-[#222] transition-opacity hover:opacity-70 sm:text-[12px]"
                >
                  {family.buttonLabel}
                </button>
              </div>
            </div>

            <div class:list={[
              'grid gap-4 sm:grid-cols-2 sm:gap-5',
              index === 0 ? 'lg:grid-cols-2' : 'lg:grid-cols-2',
            ]}>
              {family.images.map((image, imageIndex) => (
                <figure class="overflow-hidden rounded-xl bg-[#e4e4e4]">
                  <img
                    src={assetUrl(image.src)}
                    alt={image.alt}
                    class:list={[
                      'h-full w-full',
                      family.guideKey === 'camisero' && imageIndex === 2
                        ? 'object-contain scale-[1.34] translate-y-[28%]'
                        : family.guideKey === 'camisero' && [0, 3].includes(imageIndex)
                          ? 'object-contain scale-[1.34] translate-y-[16%]'
                          : 'object-cover',
                    ]}
                    loading="lazy"
                    decoding="async"
                    sizes="(min-width: 1024px) 28vw, (min-width: 640px) 46vw, 100vw"
                  />
                </figure>
              ))}
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <SizeGuideSection lang={lang} />

  <dialog id="size-guide-dialog" class="size-guide-dialog w-[min(92vw,980px)] max-h-[90dvh] max-w-245 overflow-y-auto rounded-2xl border border-[#d4d4d4] bg-white p-0 text-[#101010] shadow-[0_30px_80px_rgba(0,0,0,0.25)]">
    <div class="flex items-center justify-between border-b border-[#e2e2e2] px-4 py-3 sm:px-6 sm:py-4">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[#555] sm:text-[12px]">{copy.sizeGuideDialog.sectionLabel}</p>
        <h3 id="size-guide-title" class="catalog-serif mt-1 text-[26px] uppercase leading-none sm:text-[34px]"></h3>
      </div>
      <button id="size-guide-close" type="button" class="rounded-full border border-[#d2d2d2] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-[#333] transition-colors hover:bg-[#f2f2f2] sm:text-[12px]">
        {copy.sizeGuideDialog.closeLabel}
      </button>
    </div>

    <div class="grid gap-5 px-4 py-4 sm:px-6 sm:py-6 lg:grid-cols-[0.9fr_1.1fr] lg:gap-7">
      <img id="size-guide-image" src="" alt="" class="w-full rounded-xl border border-[#e0e0e0] bg-[#f5f5f5] object-contain" loading="lazy" decoding="async" />

      <div class="overflow-hidden rounded-xl border border-[#d8d8d8]">
        <table class="w-full border-collapse">
          <thead class="bg-[#f4f4f4] text-left text-[11px] uppercase tracking-[0.14em] text-[#333] sm:text-[12px]">
            <tr>
              {copy.sizeGuideDialog.headers.map((label) => (
                <th class="px-3 py-3 font-semibold sm:px-4">{label}</th>
              ))}
            </tr>
          </thead>
          <tbody id="size-guide-rows" class="divide-y divide-[#e8e8e8] bg-white text-[12px] sm:text-[13px]"></tbody>
        </table>
      </div>
    </div>
  </dialog>

  <section data-scroll-section class="bg-[#ececec] px-5 py-12 text-[#101010] sm:px-8 sm:py-14 lg:px-12 lg:py-16">
    <div class="mx-auto grid w-full max-w-375 gap-8 rounded-2xl border border-[#d4d4d4] bg-white p-6 sm:p-8 lg:grid-cols-2 lg:gap-10">
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-[#454545]">{copy.payment.brandLabel}</p>
        <h2 class="catalog-serif mt-2 text-[30px] uppercase leading-none sm:text-[40px]">{copy.payment.title}</h2>
        <ul class="mt-6 space-y-3 text-[12px] font-semibold uppercase tracking-[0.12em] text-[#232323] sm:text-[13px]">
          {copy.payment.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="flex flex-col justify-end">
        <p class="text-[12px] font-semibold uppercase tracking-[0.14em] text-[#454545]">{copy.contact.label}</p>
        <p class="mt-2 text-[26px] font-semibold leading-none text-[#101010] sm:text-[34px]">{copy.contact.phone}</p>
        <a
          href="https://instagram.com/bondperu__"
          target="_blank"
          rel="noreferrer"
          class="mt-5 inline-block border-b border-[#222] pb-1 text-[12px] font-semibold uppercase tracking-[0.16em] text-[#222] transition-opacity hover:opacity-70"
        >
          {copy.contact.instagram}
        </a>
      </div>
    </div>
  </section>

  <section data-scroll-section>
    <SiteFooter lang={lang} />
  </section>
</Layout>

<script define:vars={{ sizeGuides }}>
  // @ts-nocheck
  const sections = Array.from(document.querySelectorAll("section[data-scroll-section]"));
  const guideDialog = document.getElementById("size-guide-dialog");
  const guideTitle = document.getElementById("size-guide-title");
  const guideImage = document.getElementById("size-guide-image");
  const guideRows = document.getElementById("size-guide-rows");
  const guideClose = document.getElementById("size-guide-close");
  let scrollLocked = false;
  let wheelAccumulator = 0;

  function formatCm(value) {
    return value === "___" ? value : `${value} cm`;
  }

  function renderGuide(guideKey) {
    const guide = sizeGuides[guideKey];
    if (!guide || !guideTitle || !guideImage || !guideRows) return;

    guideTitle.textContent = guide.name;
    guideImage.src = guide.image;
    guideImage.alt = guide.imageAlt;

    guideRows.innerHTML = guide.rows
      .map(
        (row) => `
          <tr>
            <td class="px-3 py-4 font-semibold uppercase tracking-[0.12em] text-[#111] sm:px-4">${row.size}</td>
            <td class="px-3 py-4 text-[#6b6b6b] sm:px-4">${formatCm(row.chest)}</td>
            <td class="px-3 py-4 text-[#6b6b6b] sm:px-4">${formatCm(row.length)}</td>
            <td class="px-3 py-4 text-[#6b6b6b] sm:px-4">${formatCm(row.sleeve)}</td>
          </tr>
        `
      )
      .join("");
  }

  function getCurrentSectionIndex() {
    const viewportMiddle = window.innerHeight / 2;
    let closestIndex = 0;
    let minDistance = Number.POSITIVE_INFINITY;

    for (let index = 0; index < sections.length; index += 1) {
      const rect = sections[index].getBoundingClientRect();

      if (rect.top <= viewportMiddle && rect.bottom >= viewportMiddle) {
        return index;
      }

      const distance = Math.abs(rect.top - viewportMiddle);
      if (distance < minDistance) {
        minDistance = distance;
        closestIndex = index;
      }
    }

    return closestIndex;
  }

  function canSnapToNextSection(section, direction) {
    const rect = section.getBoundingClientRect();
    const viewportHeight = window.innerHeight;
    const threshold = 24;

    if (rect.height <= viewportHeight) return true;

    if (direction > 0) {
      return rect.bottom <= viewportHeight + threshold;
    }

    return rect.top >= -threshold;
  }

  function scrollToSection(index) {
    const target = sections[index];
    if (!target) return;
    target.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  window.addEventListener(
    "wheel",
    (e) => {
      if (sections.length < 2) return;
      if (guideDialog?.open) return;

      if (scrollLocked) {
        e.preventDefault();
        wheelAccumulator = 0;
        return;
      }

      wheelAccumulator += e.deltaY;

      if (Math.abs(wheelAccumulator) < 60) return;

      const direction = wheelAccumulator > 0 ? 1 : -1;
      const currentIndex = getCurrentSectionIndex();
      const currentSection = sections[currentIndex];

      if (!canSnapToNextSection(currentSection, direction)) {
        wheelAccumulator = 0;
        return;
      }

      const nextIndex = Math.min(Math.max(currentIndex + direction, 0), sections.length - 1);

      wheelAccumulator = 0;

      if (nextIndex === currentIndex) return;

      e.preventDefault();
      scrollLocked = true;
      wheelAccumulator = 0;
      scrollToSection(nextIndex);

      window.setTimeout(() => {
        scrollLocked = false;
        wheelAccumulator = 0;
      }, 700);
    },
    { passive: false }
  );

  document.querySelectorAll("[data-open-size-guide]").forEach((button) => {
    button.addEventListener("click", () => {
      const guideKey = button.getAttribute("data-open-size-guide");
      renderGuide(guideKey);
      guideDialog?.showModal();
    });
  });

  guideClose?.addEventListener("click", () => guideDialog?.close());
</script>