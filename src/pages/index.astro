---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import VideoCarousel from '../components/VideoCarousel.astro';
import HeroNavbar from '../components/HeroNavbar.astro';
import LookSection from '../components/LookSection.astro';
import SiteFooter from '../components/SiteFooter.astro';

// Local hero videos from public/videos
const heroVideos = [
  {
    src: '/videos/video_3.mp4'
  },
  {
    src: '/videos/video_1.mp4'
  },
  {
    src: '/videos/video_2.mp4'
  },
  {
    src: '/videos/video_4.mp4'
  }
];
---

<Layout>
  <VideoCarousel videos={heroVideos} title="BOND" subtitle="THE INVISIBLE LINK">
    <HeroNavbar slot="navbar" />
  </VideoCarousel>
  <LookSection />
  <SiteFooter />
</Layout>